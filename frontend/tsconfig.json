{
  "compilerOptions": {
    "lib": ["DOM", "DOM.Iterable", "ES2024"],
    "types": ["node", "vite/client"],
    "target": "ES2022",
    "module": "es2022",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "noEmit": true,
    "outDir": "dist",
    "rootDir": ".",
    "composite": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "src/**/*",
    "vite.config.ts"
  ]
}
